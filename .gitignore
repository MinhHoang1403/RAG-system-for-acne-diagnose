# =============================================================================
# .gitignore  –  12-Factor App / Python / Node.js / Docker
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & Secrets  (12-Factor: config in environment)
# ---------------------------------------------------------------------------
.env
.env.phase2_audit_backup
.env.pre_ui_audit_backup
.env.local
.env.*.local
.envrc
*.pem
*.key
*.crt
secrets/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.Python

# Testing & Coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
*.cover

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# Node.js / Web (src/frontend)
# ---------------------------------------------------------------------------
node_modules/
src/frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Build output
.next/
out/
dist/
src/frontend/dist/
build/
.nuxt/
.output/

# Package lock files (choose one approach – keep only what you use)
# package-lock.json
# yarn.lock

# ---------------------------------------------------------------------------
# Data & Knowledge (keep structure, exclude large/sensitive files)
# ---------------------------------------------------------------------------
data/
data/raw/
data/processed/
data/embeddings/
data/cache/
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/embeddings/.gitkeep
!data/cache/.gitkeep

# Keep sample_data structure but ignore large files
sample_data/
sample_data_*/
*.pdf
sample_data/**/*.pdf
sample_data/**/*.parquet
sample_data/**/*.arrow
!sample_data/.gitkeep

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
postgres-data/
pgdata/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
log/
reports/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
tmp/
temp/
