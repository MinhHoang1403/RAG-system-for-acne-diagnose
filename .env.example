# =============================================================================
# 12-Factor App Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development            # development | staging | production
APP_NAME=acne-agent-system
APP_VERSION=0.1.0
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# Web Layer  (src/frontend)
# ---------------------------------------------------------------------------
WEB_PORT=5173
WEB_HOST=0.0.0.0
VITE_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# API Layer  (src/api)
# ---------------------------------------------------------------------------
API_PORT=8000
API_WORKERS=4
API_RELOAD=true                # Set to false in production
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Agent Layer  (src/agent)
# ---------------------------------------------------------------------------
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120
AGENT_TEMPERATURE=0.2

# ---------------------------------------------------------------------------
# LLM / Model Providers
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3.5-flash
LLAMA_CLOUD_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# ---------------------------------------------------------------------------
# Embedding
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/gemini-embedding-2
EMBEDDING_DIMENSIONS=3072

# ---------------------------------------------------------------------------
# Database  (src/database)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/acne_agent_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Vector Database
VECTOR_DB_PROVIDER=qdrant       # qdrant | pgvector | weaviate | pinecone
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=acne_knowledge
CHUNK_QDRANT_COLLECTION_NAME=acne_knowledge
ENTITY_QDRANT_COLLECTION_NAME=acne_entities_v1

# Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=acne-agent

# ---------------------------------------------------------------------------
# Redis (Cache / Queue)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ---------------------------------------------------------------------------
# Skills Layer  (src/skills)
# ---------------------------------------------------------------------------
SKILL_TIMEOUT_SECONDS=60
SKILL_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# External APIs / Integrations
# ---------------------------------------------------------------------------
PUBMED_API_KEY=
CLINVAR_API_KEY=
OPENFDA_API_KEY=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_PROVIDER=local          # local | s3 | gcs | azure
DATA_DIR=./data
SAMPLE_DATA_DIR=./sample_data

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# --- Redis Cache ---
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_ANSWER_VERSION=v5
PROMPT_VERSION=medical_prompt_v2
KB_VERSION=acne_kb_v1
TAXONOMY_VERSION=drug_taxonomy_v1
ENTITY_SCHEMA_VERSION=entity_schema_v1
CHUNK_SCHEMA_VERSION=chunk_schema_v2
INGESTION_PIPELINE_VERSION=ingestion_pipeline_v2
CACHE_MAX_QUESTION_CHARS=600
CACHE_MAX_HISTORY_MESSAGES=2
CACHE_MIN_ANSWER_CHARS=350
CACHE_REQUIRED_ENTITY_CHECK=true
ANSWER_VERIFIER_ENABLED=true
ANSWER_GUARD_MODE=metadata_only
ANSWER_VERIFIER_STRICT=false
OBSERVABILITY_ENABLED=false
OBSERVABILITY_TRACE_DIR=logs/phase2_traces
OBSERVABILITY_MAX_TEXT_CHARS=500
PHASE2_DEBUG_METADATA=false

# --- Input Control ---
MAX_MESSAGE_CHARS=500
MAX_MESSAGE_WORDS=120
MAX_QUESTION_MARKS=3
MAX_CONVERSATION_HISTORY_MESSAGES=10
MAX_HISTORY_MESSAGE_CHARS=1000
