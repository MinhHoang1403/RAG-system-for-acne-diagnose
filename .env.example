# =============================================================================

# ACNE ADVISOR AI - LOCAL DEVELOPMENT ENVIRONMENT

# =============================================================================

# Khong commit file .env len Git.

# Khong chia se API key hoac mat khau that.

# Model semantic reranker phai ton tai san tren may.

# Khong thay embedding model hoac dimensions neu chua rebuild Qdrant.

# =============================================================================

# -----------------------------------------------------------------------------

# Application / API

# -----------------------------------------------------------------------------

APP_ENV=development
APP_NAME=acne-agent-system
APP_VERSION=0.1.0

API_PORT=8000
API_WORKERS=1
API_RELOAD=true

LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
PREFLIGHT_CHECK_TIMEOUT_SECONDS=4.0

# -----------------------------------------------------------------------------

# Frontend

# -----------------------------------------------------------------------------

VITE_API_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------

# External API Providers

# Chi dien API key that trong file .env local.

# -----------------------------------------------------------------------------

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3.5-flash
GOOGLE_FALLBACK_MODELS=gemini-3.1-flash-lite

LLAMA_CLOUD_API_KEY=

# -----------------------------------------------------------------------------

# Ollama Local LLM

# -----------------------------------------------------------------------------

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# -----------------------------------------------------------------------------

# Embedding

# Khong thay doi model hoac dimensions neu chua rebuild Qdrant.

# -----------------------------------------------------------------------------

EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/gemini-embedding-2
EMBEDDING_DIMENSIONS=3072

# -----------------------------------------------------------------------------

# Knowledge Base / Schema / Pipeline Versioning

# -----------------------------------------------------------------------------

KB_VERSION=acne_kb_v1

TAXONOMY_VERSION=drug_taxonomy_v1
ENTITY_FOUNDATION_VERSION=entity_foundation_v2
ENTITY_SCHEMA_VERSION=entity_schema_v1
CHUNK_SCHEMA_VERSION=chunk_schema_v2

INGESTION_PIPELINE_VERSION=ingestion_pipeline_v2
PROMPT_VERSION=medical_prompt_v2

ANSWER_FORMATTING_CONTRACT_VERSION=answer_formatting_contract_v6
GOOGLE_GENAI_SDK_VERSION=google_genai_sdk_v1
REPRODUCIBLE_ENVIRONMENT_VERSION=reproducible_environment_v1
END_TO_END_RELEASE_READINESS_VERSION=end_to_end_release_readiness_v1

# -----------------------------------------------------------------------------

# Ingestion

# Khong chay ingestion hoac rebuild collection neu chua co ke hoach rieng.

# -----------------------------------------------------------------------------

DATA_DIR=./data
SAMPLE_DATA_DIR=./sample_data

CHUNK_SIZE=2000

LLM_CONCURRENCY=1
INGEST_BATCH_SIZE=16
GRAPH_BATCH_SIZE=20

EMBEDDING_BATCH_DELAY=12
EMBEDDING_MAX_RETRIES=10
EMBEDDING_RETRY_BASE_DELAY=8

# -----------------------------------------------------------------------------

# PostgreSQL

# Host port 5433 de tranh xung dot voi PostgreSQL hoac Odoo tai port 5432.

# -----------------------------------------------------------------------------

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=acne_agent_db
POSTGRES_PORT=5433

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/acne_agent_db
SYNC_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5433/acne_agent_db

# -----------------------------------------------------------------------------

# Neo4j

# -----------------------------------------------------------------------------

NEO4J_AUTH=neo4j/password

NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# -----------------------------------------------------------------------------

# Qdrant

# -----------------------------------------------------------------------------

VECTOR_DB_PROVIDER=qdrant

QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

QDRANT_COLLECTION_NAME=acne_knowledge
CHUNK_QDRANT_COLLECTION_NAME=acne_knowledge
ENTITY_QDRANT_COLLECTION_NAME=acne_entities_v1

FORCE_RECREATE_QDRANT_COLLECTION=false

# -----------------------------------------------------------------------------

# Redis / Answer Cache

# -----------------------------------------------------------------------------

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
CACHE_SIMILARITY_THRESHOLD=0.92

CACHE_ANSWER_VERSION=v5

CACHE_MAX_QUESTION_CHARS=600
CACHE_MAX_HISTORY_MESSAGES=2
CACHE_MIN_ANSWER_CHARS=350
CACHE_REQUIRED_ENTITY_CHECK=true

# -----------------------------------------------------------------------------

# Input Control

# -----------------------------------------------------------------------------

MAX_MESSAGE_CHARS=500
MAX_MESSAGE_WORDS=120
MAX_QUESTION_MARKS=3

MAX_CONVERSATION_HISTORY_MESSAGES=10
MAX_HISTORY_MESSAGE_CHARS=1000

# -----------------------------------------------------------------------------

# Retrieval

# -----------------------------------------------------------------------------

RETRIEVE_CANDIDATE_TOP_K=50

# -----------------------------------------------------------------------------

# Semantic Reranker

# Pipeline:

# Qdrant retrieval -> semantic CrossEncoder -> local rules -> retrieval score

# -----------------------------------------------------------------------------

RERANK_ENABLED=true
RERANK_PROVIDER=hybrid
RERANK_TOP_N=8

SEMANTIC_RERANK_MODEL_PATH=C:/Models/acne-reranker/bge-reranker-v2-m3
SEMANTIC_RERANK_DEVICE=cuda

SEMANTIC_RERANK_BATCH_SIZE=4
SEMANTIC_RERANK_MAX_CANDIDATES=16

SEMANTIC_RERANK_MAX_QUERY_CHARS=1000
SEMANTIC_RERANK_MAX_DOCUMENT_CHARS=4000

SEMANTIC_RERANK_ALLOW_FALLBACK=true

SEMANTIC_RERANK_WEIGHT=0.70
RULE_RERANK_WEIGHT=0.20
RETRIEVAL_RERANK_WEIGHT=0.10

# -----------------------------------------------------------------------------

# Answer Verifier / Answer Guard

# -----------------------------------------------------------------------------

ANSWER_VERIFIER_ENABLED=true
ANSWER_VERIFIER_STRICT=false
ANSWER_GUARD_MODE=metadata_only

SEVERITY_GUARD_VERSION=severity_aware_answer_guard_v1

# -----------------------------------------------------------------------------

# Safe Fallback Flow

# -----------------------------------------------------------------------------

SAFE_FALLBACK_FLOW_VERSION=safe_fallback_flow_v1

# -----------------------------------------------------------------------------

# Runtime Resilience

# -----------------------------------------------------------------------------

AGENT_TOTAL_TIMEOUT_SECONDS=120

RETRIEVAL_TIMEOUT_SECONDS=20
NEO4J_TIMEOUT_SECONDS=10
RERANK_TIMEOUT_SECONDS=20
GEMINI_TIMEOUT_SECONDS=45
OLLAMA_TIMEOUT_SECONDS=90

LLM_MAX_RETRIES=1
LLM_RETRY_BASE_DELAY_SECONDS=1
LLM_RETRY_MAX_DELAY_SECONDS=4

CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_SECONDS=60
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=1

RUNTIME_RESILIENCE_VERSION=runtime_resilience_v1

# -----------------------------------------------------------------------------

# Observability / Debug

# -----------------------------------------------------------------------------

OBSERVABILITY_ENABLED=false
OBSERVABILITY_TRACE_DIR=logs/phase2_traces
OBSERVABILITY_MAX_TEXT_CHARS=500

PHASE2_DEBUG_METADATA=false

# -----------------------------------------------------------------------------

# Local Model Offline Policy

# Khong cho Transformers hoac Hugging Face tu tai model trong runtime.

# -----------------------------------------------------------------------------

HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
